# --- LLM provider --------------------------------------------------------
# HUXForm is provider-agnostic. Pick either protocol:
#   anthropic  → Anthropic Messages API     (Anthropic, MiniMax, AWS Bedrock proxy, ...)
#   openai     → OpenAI Chat Completions    (OpenAI, OpenRouter, Groq, Together, Ollama, ...)
#
# Just point AGUI_LLM_BASE_URL at the provider and set the model id they
# expose. Any model that speaks the protocol works — Claude, GPT, Llama,
# Mistral, Qwen, DeepSeek, MiniMax, anything.
AGUI_LLM_PROTOCOL=anthropic
AGUI_LLM_BASE_URL=https://api.anthropic.com
AGUI_LLM_MODEL=claude-opus-4-7
AGUI_LLM_API_KEY=your_api_key_here
AGUI_LLM_MAX_TOKENS=4096
AGUI_LLM_TEMPERATURE=0.6

# --- OpenAI-compatible example -------------------------------------------
# AGUI_LLM_PROTOCOL=openai
# AGUI_LLM_BASE_URL=https://api.openai.com/v1
# AGUI_LLM_MODEL=gpt-4o-mini
# AGUI_LLM_API_KEY=sk-...

# --- Web search ----------------------------------------------------------
# web.search uses DuckDuckGo by default — no key required, real results.
# Set one of these for an alternative provider (auto-detected at call time):
# TAVILY_API_KEY=tvly-...    # https://tavily.com  — best quality
# BRAVE_API_KEY=...          # https://search.brave.com/api  — 2k req/mo free
# SERPER_API_KEY=...         # https://serper.dev  — Google results

# --- MCP servers ---------------------------------------------------------
# Default config path: .agui/mcp.json — seeded from .agui/mcp.json.example
# on first `./bin/huxform setup`. Edit that file to add or remove servers.
# AGUI_MCP_CONFIG=.agui/mcp.json

# --- CLI tools -----------------------------------------------------------
# CLI tools (cli.git, cli.curl, ...) are ON by default in fresh setups so
# the agent can wrap host binaries. Every call still requires explicit
# approval through the bridge. Disable by setting to 0, or restrict with
# the allowlist below.
AGUI_ENABLE_CLI=1
# AGUI_CLI_ALLOWLIST=git:gh:jq:curl

# --- Storage -------------------------------------------------------------
# Persistence + uploaded files live here.
# AGUI_DATA_DIR=.huxform-data
