# AGUI talks to any provider that speaks the Anthropic Messages API
# or the OpenAI Chat Completions API. Default below is MiniMax M2 via
# its Anthropic-compatible endpoint.
#
# Switch providers by changing AGUI_LLM_PROTOCOL + AGUI_LLM_BASE_URL.

AGUI_LLM_PROTOCOL=anthropic
AGUI_LLM_BASE_URL=https://api.minimax.io/anthropic
AGUI_LLM_MODEL=MiniMax-M2
AGUI_LLM_API_KEY=your_minimax_key_here

# Optional tuning
AGUI_LLM_MAX_TOKENS=4096
AGUI_LLM_TEMPERATURE=0.6

# --- OpenAI-compatible example (uncomment to use) ---
# AGUI_LLM_PROTOCOL=openai
# AGUI_LLM_BASE_URL=https://api.openai.com/v1
# AGUI_LLM_MODEL=gpt-4o-mini
# AGUI_LLM_API_KEY=sk-...
